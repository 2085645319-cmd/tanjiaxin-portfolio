---
import type { Work } from '../data/works';
import { sitePath } from '../lib/sitePath';

interface Props {
  work: Work;
}

const { work } = Astro.props;
---

<article class="card">
  <a href={sitePath(`work/${work.slug}`)} class="thumb-link focus-ring">
    <img src={sitePath(work.poster.replace(/^\//, ''))} alt={`${work.title} 宣传图`} loading="lazy" />
    <span class="platform">{work.platformBadge}</span>
  </a>
  <div class="body">
    <h2 class="title">
      <a href={sitePath(`work/${work.slug}`)}>{work.title}</a>
    </h2>
    <p class="meta">
      {work.category} · {work.period}
    </p>
    <p class="desc">{work.description}</p>
    <a class="more" href={sitePath(`work/${work.slug}`)}>查看详情 →</a>
  </div>
</article>

<style>
  .card {
    display: grid;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    width: 100%;
    max-width: 320px;
    break-inside: avoid;
    page-break-inside: avoid; 
    -webkit-column-break-inside: avoid;
  }

  .thumb-link {
    position: relative;
    display: block;
    border-radius: calc(var(--radius) - 4px);
    overflow: hidden;
    border: 1px solid var(--border);
    background-color: #f5f5f5;
    width: 100%;
  }

  .thumb-link img {
    width: 100%;
     height: auto;
    object-fit: contain;
    display: block;
  }

  .body {
    width: 100%;
  }

  .platform {
    position: absolute;
    left: 0.5rem;
    bottom: 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    padding: 0.2rem 0.5rem;
    border-radius: 6px;
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    border: 1px solid var(--border);
    color: var(--text);
  }

  .title {
    margin: 0;
    font-size: 1.15rem;
  }

  .title a {
    color: var(--text);
    text-decoration: none;
  }

  .title a:hover {
    color: var(--accent);
  }

  .meta {
    margin: 0.25rem 0 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .desc {
    margin: 0.5rem 0 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .more {
    display: inline-block;
    margin-top: 0.75rem;
    font-weight: 600;
    font-size: 0.9rem;
  }
</style>
<script>
  import ColorThief from 'https://cdn.jsdelivr.net/npm/colorthief@2.3.2/dist/color-thief.mjs';

  const FALLBACK_COLOR = '#f5f5f5';  

  document.addEventListener('DOMContentLoaded', () => {
    const colorThief = new ColorThief();
    const thumbLinks = document.querySelectorAll('.thumb-link');

    thumbLinks.forEach(container => {
      const img = container.querySelector('img');
      if (!img) return;

      const applyFallback = () => {
        container.style.backgroundColor = FALLBACK_COLOR;
      };

      const setColor = () => {
        try {
          const dominantColor = colorThief.getColor(img);
          container.style.backgroundColor = `rgb(${dominantColor[0]}, ${dominantColor[1]}, ${dominantColor[2]})`;
        } catch (e) {
          console.warn('提取主色失败，使用回退色', e);
          applyFallback();
        }
      };

      if (img.complete) {
        setColor();
      } else {
        img.addEventListener('load', setColor);
        img.addEventListener('error', applyFallback);
      }
    });
  });
</script>