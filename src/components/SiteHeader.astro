---
import { sitePath } from '../lib/sitePath';

const links = [
  { href: sitePath(''), label: '作品' },
  { href: sitePath('about'), label: '关于' },
  { href: sitePath('contact'), label: '联系' },
];
---

<header class="header">
  <div class="inner">
    <a href={sitePath('')} class="brand focus-ring">tanjiaxin</a>
    <nav class="nav" aria-label="主导航">
      <ul>
        {
          links.map(({ href, label }) => (
            <li>
              <a href={href} class="focus-ring">
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .inner {
    width: min(1100px, 100% - 2rem);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0;
  }

  .brand {
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: lowercase;
    color: var(--text);
    text-decoration: none;
  }

  .brand:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .nav a {
    color: var(--accent);           /* 改成更醒目的颜色（主题色） */
    font-weight: 600;               /* 加粗 */
    font-size: 1rem;                /* 稍大一点 */
    background-color: transparent;  /* 背景透明 */
    border: 1px solid var(--border);/* 添加边框 */
    padding: 0.4rem 0.8rem;         /* 内边距，让按钮有呼吸感 */
    border-radius: 2rem;            /* 圆角，更现代 */
    transition: all 0.2s ease;  
  }

  .nav a:hover {
    color: var(--bg);               /* 悬停时文字颜色反白 */
    background-color: var(--accent);/* 悬停时背景色填充为强调色 */
    border-color: var(--accent);
  }
</style>
