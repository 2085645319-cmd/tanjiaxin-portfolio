---
import Layout from '../../layouts/Layout.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import { works } from '../../data/works';
import { sitePath } from '../../lib/sitePath';

export function getStaticPaths() {
  return works.map((work) => ({
    params: { slug: work.slug },
    props: { work },
  }));
}

const { work } = Astro.props;
const hasWatch = Boolean(work.watchUrl?.trim());
const bottomMessage = hasWatch
  ? null
  : work.noWatchMessage ?? '观看链接持续更新';
---

<Layout title={`${work.title} — 谭佳欣`} description={work.description}>
  <article class="detail">
    <p class="back">
      <a href={sitePath('')} class="focus-ring">← 返回作品列表</a>
    </p>
    <header class="head">
      <p class="meta">
        {work.category} · {work.period} · {work.platformBadge}
      </p>
      <h1>{work.title}</h1>
      <p class="desc">{work.description}</p>
    </header>

  <div class="player">
  {work.videoUrl ? (
    <video controls width="100%">
      <source src={work.videoUrl} type="video/mp4" />
      您的浏览器不支持视频播放。
    </video>
  ) : work.embedUrl ? (
    <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;">
      <iframe
        src={work.embedUrl}
        frameborder="0"
        allowfullscreen
        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
      ></iframe>
    </div>
  ) : (
    <VideoEmbed
      embedUrl={work.embedUrl}
      poster={work.poster}
      title={work.title}
      pendingMessage={work.pendingMessage}
    />
  )}
</div>

    <p class="fallback">
      {
        hasWatch ? (
         <a href={work.watchUrl} class="focus-ring" target="_blank" rel="noopener noreferrer" referrerpolicy="no-referrer">
          在原平台打开
           </a>
        ) : (
          <span class="pending-link">{bottomMessage}</span>
        )
      }
    </p>
  </article>
</Layout>

<style>
  .detail {
    max-width: 900px;
    margin: 0 auto;
  }

  .back {
    margin: 0 0 1.25rem;
  }

  .head .meta {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
  }

  .head h1 {
    margin: 0.35rem 0 0.75rem;
    font-size: clamp(1.5rem, 3vw, 2rem);
  }

  .desc {
    margin: 0;
    color: var(--muted);
    max-width: 42rem;
  }

  .player {
    margin: 1.75rem 0 1rem;
  }

  .fallback {
    margin: 0;
    font-size: 1.0rem;
    font-weight: 500;
  }

  .pending-link {
    color: var(--muted);
  }
</style>
