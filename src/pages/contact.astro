---
import Layout from '../layouts/Layout.astro';

const phone = '18208113780';
const telHref = `tel:${phone}`;
const email = '2085645319@qq.com';
const mailHref = `mailto:${email}`;
---

<Layout
  title="联系 — 谭佳欣（tanjiaxin）"
  description="联系谭佳欣：手机 / 微信、QQ 邮箱。"
>
  <article class="prose">
    <h1>联系</h1>
    <ul class="list">
      <li>
        <span class="label">手机号（微信同号）</span>
        <a href={telHref} class="value focus-ring">{phone}</a>
      </li>
      <li>
        <span class="label">QQ 邮箱</span>
        <a href={mailHref} class="value focus-ring">{email}</a>
      </li>
    </ul>
  </article>
</Layout>

<style>
  .prose {
    max-width: 42rem;
  }

  .prose h1 {
    margin-top: 0;
    margin-bottom: 1.25rem;
  }

  .list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .list li {
    padding: 1rem 1.15rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .label {
    font-size: 0.85rem;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .value {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
    text-decoration: none;
    word-break: break-all;
  }

  .value:hover {
    text-decoration: underline;
    color: var(--accent-hover);
  }
</style>
